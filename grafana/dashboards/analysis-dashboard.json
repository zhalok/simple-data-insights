      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Sentiment score analysis",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
