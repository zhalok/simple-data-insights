                      },
                      "spec": {
                        "dataset": "postgres",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  CASE\n    WHEN sentiment_score >= 0  AND sentiment_score < 25  THEN '0-25'\n    WHEN sentiment_score >= 25 AND sentiment_score < 50  THEN '25-50'\n    WHEN sentiment_score >= 50 AND sentiment_score < 75  THEN '50-75'\n    WHEN sentiment_score >= 75 AND sentiment_score <= 100 THEN '75-100'\n  END AS score_range,\n  COUNT(*) AS count\nFROM takapay_posts\nGROUP BY score_range\nORDER BY score_range;\n",
                        "sql": {
                          "columns": [
